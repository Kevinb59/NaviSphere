# Copier ce fichier en `.env.local` dans le dossier `web/` et coller la config Web de la console Firebase.
# Sur Vercel : Project Settings → Environment Variables → mêmes noms avec préfixe VITE_.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=

# Optionnel (snippet SDK complet) :
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_MEASUREMENT_ID=
